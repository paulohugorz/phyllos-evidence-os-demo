{
  "expo": {
    "name": "PHYLLOS Evidence OS",
    "slug": "phyllos-evidence-os-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "phyllos-evidence",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phyllos.evidenceos",
      "infoPlist": {
        "NSCameraUsageDescription": "A PHYLLOS usa a câmera para registrar peças, tecidos, etiquetas e evidências da produção.",
        "NSPhotoLibraryUsageDescription": "A PHYLLOS acessa suas fotos para anexar registros à produção."
      }
    },
    "android": {
      "package": "com.phyllos.evidenceos",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que a PHYLLOS selecione fotos para registrar a produção.",
          "cameraPermission": "Permitir que a PHYLLOS fotografe peças, tecidos e evidências."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EE"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "CONFIGURE_COM_EAS_INIT"
      }
    }
  }
}
