{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phyllos.local/contracts/pi5-training-record.schema.json",
  "title": "PHYLLOS PI5 Training Record",
  "type": "object",
  "required": [
    "recordId",
    "sampleId",
    "lineageGroupKey",
    "category",
    "features",
    "target",
    "quality",
    "provenance"
  ],
  "properties": {
    "recordId": {
      "type": "string",
      "minLength": 1
    },
    "sampleId": {
      "type": "string",
      "minLength": 1
    },
    "lineageGroupKey": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "features": {
      "type": "object"
    },
    "target": {
      "type": "object",
      "required": [
        "globalScore",
        "dimensionScores",
        "tier"
      ],
      "properties": {
        "globalScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "dimensionScores": {
          "type": "object"
        },
        "tier": {
          "enum": [
            "gold",
            "silver"
          ]
        }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "required": [
        "coverage",
        "confidence",
        "evidenceQuality",
        "reviewerCount"
      ],
      "properties": {
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "evidenceQuality": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "reviewerCount": {
          "type": "integer",
          "minimum": 2
        },
        "adjudicated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "methodologyVersion",
        "benchmarkVersion",
        "modelVersion",
        "inputHash",
        "labelHash"
      ],
      "properties": {
        "methodologyVersion": {
          "type": "string"
        },
        "benchmarkVersion": {
          "type": "string"
        },
        "modelVersion": {
          "type": "string"
        },
        "inputHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "labelHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "assetHashes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
